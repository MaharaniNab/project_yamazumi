{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "dockerfile": "api/Dockerfile",
    "buildContext": "."
  },
  "deploy": {
    "startCommand": "cd /app && gunicorn index:app --bind 0.0.0.0:$PORT --workers 2 --timeout 300 --access-logfile - --error-logfile -",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5
  }
}
